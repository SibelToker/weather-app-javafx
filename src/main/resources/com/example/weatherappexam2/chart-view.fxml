<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.chart.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox alignment="CENTER" spacing="10" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.example.weatherappexam2.ChartController">

    <Label fx:id="titleLabel" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>

    <LineChart fx:id="lineChart" prefHeight="300" prefWidth="500">
        <xAxis>
            <CategoryAxis label="Time" />
        </xAxis>
        <yAxis>
            <NumberAxis label="Value" />
        </yAxis>
    </LineChart>
</VBox>